  background:    linear-gradient(
    180deg,
    rgba(255, 100, 100, 0.40),
    rgba(100, 200, 255, 0.40),
    rgba(150, 100, 255, 0.40)
  );
  border-radius: 1px;
  /* Thumb only appears on sidebar hover via opacity on the containing rule */
  opacity: 0;
  transition: opacity 0.2s ease;
}
.sidebar:hover .sidebar__content::-webkit-scrollbar-thumb { opacity: 0.70; }


/* ── Placeholder for unimplemented tabs ─────────────────── */
