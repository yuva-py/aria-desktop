/* src/components/sidebar/Sidebar.css
   ─────────────────────────────────────
   Main panel + tab bar + pipeline node styles.
   All colour-sensitive values use CSS vars so both
   crystal and obsidian themes work without overrides.

   Sidebar enters via blur+materialize (not a full slide)
   so no transform-based hidden state is needed here.    */


/* ── Panel shell ─────────────────────────────────────────── */
.sidebar {
  position:   fixed;
  left:       0;
  top:        0;
  width:      300px;
  height:     100vh;
  z-index:    20;

  display:        flex;
  flex-direction: column;
  overflow:       hidden;

  /* Obsidian-first background */
  background:      rgba(8, 6, 12, 0.92);
  backdrop-filter: blur(22px) saturate(1.35);
  -webkit-backdrop-filter: blur(22px) saturate(1.35);

  /* Right edge: transparent so the ::after gradient line shows */
  border-right: 1px solid transparent;
  background-clip: padding-box;
  box-shadow:
    1px 0 0 0 rgba(255, 100, 100, 0.15),
    4px 0 40px rgba(0, 0, 0, 0.65);
}

/* Crystal theme */
body.crystal .sidebar {
  background: rgba(245, 243, 255, 0.90);
  box-shadow:
    1px 0 0 0 rgba(124, 58, 237, 0.18),
    4px 0 40px rgba(124, 58, 237, 0.08);
}

/* ── Top vignette ────────────────────────────────────────── */
/* Subtle gradient from slightly lighter → panel colour at top */
.sidebar::before {
  content:  '';
  position: absolute;
  top:    0;
  left:   0;
  right:  0;
  height: 48px;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.025) 0%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 1;
}
body.crystal .sidebar::before {
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.08) 0%,
    transparent 100%
  );
}

/* ── Animated spectral right-edge ────────────────────────── */
/* ::after draws the gradient line; slow hue-rotate animates it */
.sidebar::after {
  content:  '';
  position: absolute;
  top:    0;
  right: -1px;
  width:  1px;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(255, 100, 100, 0.50),
    rgba(255, 200,   0, 0.50),
    rgba(100, 255, 200, 0.50),
    rgba(150, 100, 255, 0.50)
  );
  pointer-events: none;
  /* Slow spectrum drift — 12 s full cycle */
  animation: sidebar-edge-hue 12s linear infinite;
}

@keyframes sidebar-edge-hue {
  0%   { filter: hue-rotate(0deg);   }
  100% { filter: hue-rotate(360deg); }
}


/* ── Tab bar ─────────────────────────────────────────────── */
.sidebar__tabs {
  display:     flex;
  flex-shrink: 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  padding:     0 4px;
  position:    relative;   /* stacking context for tab indicator */
  z-index:     2;
}

body.crystal .sidebar__tabs {
  border-bottom-color: rgba(124, 58, 237, 0.12);
}

.sidebar__tab {
  flex:       1;
  padding:    12px 0 10px;
  border:     none;
  background: transparent;
  cursor:     pointer;
  position:   relative;

  font-family:    var(--font-ui);
  font-size:      10px;
  font-weight:    500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color:          var(--text-secondary);

  transition: color 0.2s ease;
}

.sidebar__tab:hover {
  color: var(--text-primary);
}

.sidebar__tab--active {
  color: var(--text-primary);
  /* Spectral glow on the active tab label */
  text-shadow: 0 0 8px var(--accent, rgba(150, 100, 255, 0.6));
}


/* ── Sliding tab indicator (layoutId="sidebar-tab-indicator") ── */
/* Framer Motion springs this element between tabs.               */
.sidebar__tab-indicator {
  position:       absolute;
  bottom:         0;
  left:           12%;
  width:          76%;
  height:         2px;
  border-radius:  2px 2px 0 0;
  background: linear-gradient(
    90deg,
    rgba(255, 100, 100, 0.85),
    rgba(255, 200,   0, 0.85),
    rgba(100, 255, 200, 0.85),
    rgba(150, 100, 255, 0.85)
  );
  /* Very slow hue drift on the indicator too */
  animation:      sidebar-edge-hue 8s linear infinite;
  /* Must not intercept clicks — the button below handles them */
  pointer-events: none;
}


/* ── Tab content area ────────────────────────────────────── */
.sidebar__content {
  flex:       1;
  overflow-y: auto;
  overflow-x: hidden;
  padding:    0;
  position:   relative;
  z-index:    0;
