/* src/components/Tier3Panel.css
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   Bottom-sheet destructive-action confirmation panel.
   Framer Motion handles mount/unmount animation (y + opacity).
   CSS handles the SVG arc sweep, button pulse, and theming.
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */


/* ── Backdrop ───────────────────────────────────────────────── */
/* Blurs the rest of the UI when the panel rises; lives in App.jsx */
.t3-backdrop {
  position:       fixed;
  inset:          0;
  z-index:        59;    /* just below the panel (z=60) */
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  background:     rgba(0, 0, 0, 0.15);
  pointer-events: none;
}

body.crystal .t3-backdrop {
  background: rgba(0, 0, 0, 0.08);
}


/* ── Panel shell ────────────────────────────────────────────── */
.t3-panel {
  position:  fixed;
  bottom:    0;
  left:      16px;
  transform: none;
  z-index:   60;         /* above sidebar (z=20) and handle (z=25) */

  width:         380px;
  max-width:     calc(50vw - 24px);
  padding:       20px 22px;
  border-radius: 14px 14px 0 0;

  /* Obsidian (default) */
  background:      rgba(12, 6, 8, 0.95);
  backdrop-filter: blur(20px) saturate(1.4);
  -webkit-backdrop-filter: blur(20px) saturate(1.4);

  /* Danger top border */
  border-top:  2px solid rgba(255, 80, 80, 0.50);
  border-left: 1px solid rgba(255, 80, 80, 0.12);
  border-right: 1px solid rgba(255, 80, 80, 0.12);

  /* Upward danger glow */
  box-shadow:
    0 -20px 60px rgba(255, 40, 40, 0.15),
    0 -4px  20px rgba(255, 40, 40, 0.08),
    inset 0 1px 0 rgba(255, 120, 120, 0.06);

  display:        flex;
  flex-direction: column;
  gap:            16px;
}

/* Crystal theme override */
body.crystal .t3-panel {
  background: rgba(248, 240, 245, 0.95);
  box-shadow:
    0 -20px 60px rgba(255, 40, 40, 0.10),
    0 -4px  20px rgba(255, 40, 40, 0.06),
    inset 0 1px 0 rgba(255, 100, 100, 0.08);
}


/* ── Top row ────────────────────────────────────────────────── */
.t3-top-row {
  display:     flex;
  align-items: center;
  gap:         9px;
}

.t3-warning-icon {
  font-size:  16px;
  color:      rgba(255, 160, 0, 0.90);
  flex-shrink: 0;
  line-height: 1;
  /* Subtle amber glow */
  filter: drop-shadow(0 0 6px rgba(255, 160, 0, 0.45));
}

.t3-header-text {
  font-size:   13px;
  font-weight: 400;
  font-family: 'Inter', system-ui, sans-serif;
  color:       var(--text-secondary);
  flex:        1;
}

/* X dismiss button */
.t3-close-btn {
  width:         26px;
  height:        26px;
  border-radius: 50%;
  border:        none;
  background:    rgba(255, 255, 255, 0.06);
  color:         var(--text-secondary);
  font-size:     11px;
  cursor:        pointer;
  display:       flex;
  align-items:   center;
  justify-content: center;
  flex-shrink:   0;
  transition:    background 0.15s ease, color 0.15s ease;
}

.t3-close-btn:hover {
  background: rgba(255, 80, 80, 0.15);
  color:      rgba(255, 120, 120, 0.95);
}

body.crystal .t3-close-btn {
  background: rgba(0, 0, 0, 0.06);
  color:      rgba(30, 20, 40, 0.50);
}

body.crystal .t3-close-btn:hover {
  background: rgba(255, 80, 80, 0.10);
  color:      rgba(200, 40, 40, 0.90);
}


/* ── Body ────────────────────────────────────────────────────── */
.t3-body {
  display:        flex;
  flex-direction: column;
  gap:            6px;
}

/* Action name — monospace, crimson accent, hexagon prefix */
.t3-action-name {
  font-size:      15px;
  font-weight:    600;
  font-family:    var(--font-mono);
  color:          var(--accent);    /* crimson in obsidian, violet in crystal */
  letter-spacing: 0.10em;
  line-height:    1.3;
}

/* Hexagon indicator prefix */
.t3-action-name::before {
  content:     '⬡ ';
  font-size:   11px;
  opacity:     0.70;
  letter-spacing: 0;
}

body.crystal .t3-action-name {
  color: var(--accent);
}

/* Target path — hover expands to show full text via max-width animation */
.t3-path {
  font-size:      12px;
  font-family:    var(--font-mono);
  color:          rgba(255, 255, 255, 0.45);
  white-space:    nowrap;
  overflow:       hidden;
  text-overflow:  ellipsis;
  letter-spacing: 0.01em;
  display:        inline-block;
  max-width:      280px;
  cursor:         default;
  transition:     max-width 0.30s ease, text-overflow 0.30s;
}

.t3-path:hover {
  max-width:    100%;
  text-overflow: clip;
}

body.crystal .t3-path {
  color: rgba(30, 10, 20, 0.45);
}

/* Reason — italic, muted */
.t3-reason {
  font-size:   11px;
  font-weight: 400;
  font-style:  italic;
  font-family: 'Inter', system-ui, sans-serif;
  color:       var(--text-secondary);
  opacity:     0.75;
  line-height: 1.5;
}


/* ── Button row ─────────────────────────────────────────────── */
.t3-actions {
  display:         flex;
  align-items:     center;
  justify-content: flex-end;
  gap:             12px;
  padding-top:     4px;
}

/* Shared button base */
.t3-btn {
  border:        none;
  cursor:        pointer;
  font-family:   'Inter', system-ui, sans-serif;
  font-size:     13px;
  font-weight:   500;
  padding:       8px 18px;
  border-radius: 8px;
  line-height:   1;
  transition:    background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
  white-space:   nowrap;
}

/* Cancel — ghost */
.t3-btn--cancel {
  background:  rgba(255, 255, 255, 0.08);
  border:      1px solid rgba(255, 255, 255, 0.12);
  color:       var(--text-secondary);
}

.t3-btn--cancel:hover {
  background:  rgba(255, 255, 255, 0.13);
  color:       var(--text-primary);
}

body.crystal .t3-btn--cancel {
  background:  rgba(0, 0, 0, 0.05);
  border-color: rgba(0, 0, 0, 0.10);
  color:       rgba(30, 10, 20, 0.60);
}

body.crystal .t3-btn--cancel:hover {
  background: rgba(0, 0, 0, 0.09);
  color:      rgba(30, 10, 20, 0.85);
}


/* ── Confirm wrapper (button + SVG arc overlay) ──────────────── */
.t3-confirm-wrapper {
  position: relative;
  display:  inline-flex;
  align-items: center;
  justify-content: center;
}

/* Confirm — waiting state */
.t3-btn--confirm {
  background:  rgba(255, 80, 80, 0.20);
  border:      1px solid rgba(255, 80, 80, 0.25);
  color:       rgba(255, 180, 180, 0.70);
  cursor:      not-allowed;
  /* Extra horizontal padding to accommodate arc overlay */
  padding:     8px 18px;
}

/* Confirm — ready state */
.t3-btn--confirm-ready {
  background:  rgba(255, 80, 80, 0.70);
  border-color: rgba(255, 80, 80, 0.50);
  color:        #fff;
  cursor:       pointer;
  animation:   t3-pulse 1.8s ease-in-out infinite;
}

.t3-btn--confirm-ready:hover {
  background:  rgba(255, 60, 60, 0.88);
  box-shadow:  0 0 20px rgba(255, 60, 60, 0.40);
  animation:   none;
}

body.crystal .t3-btn--confirm-ready {
  background:  rgba(220, 40, 40, 0.75);
  border-color: rgba(220, 40, 40, 0.55);
}

/* Pulse animation for ready confirm button */
@keyframes t3-pulse {
  0%, 100% { box-shadow: 0 0 0   0 rgba(255, 80, 80, 0.00); }
  50%       { box-shadow: 0 0 16px 4px rgba(255, 80, 80, 0.30); }
}


/* ── SVG arc countdown overlay ──────────────────────────────── */
.t3-arc {
  position:      absolute;
  top:           50%;
  right:         8px;
  transform:     translateY(-50%);
  pointer-events: none;
  width:         34px;
  height:        34px;
  overflow:      visible;
}

/* The animated fill stroke */
@keyframes t3-arc-sweep {
  from { stroke-dashoffset: var(--t3-arc-circ); }
  to   { stroke-dashoffset: 0; }
}

.t3-arc__fill {
  animation:         t3-arc-sweep 2000ms linear both;
  will-change:       stroke-dashoffset;
  stroke-dashoffset: 0;
}
