/* src/components/shared/CursorLens.css
   ───────────────────────────────────────
   Small refraction "flare" that appears near the cursor when it's near
   the orb rim. Pure presentational; position is driven by Framer Motion. */

.cursor-lens {
  position: fixed;
  top:      0;
  left:     0;
  width:    16px;
  height:   16px;
  margin-left: -8px;     /* center on cursor */
  margin-top:  -8px;
  border-radius: 50%;

  /* Soft white radial — feels like light bending through glass */
  background:
    radial-gradient(
      circle,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(200, 220, 255, 0.55) 30%,
      rgba(150, 200, 255, 0.25) 55%,
      transparent 80%
    );

  /* Faint chromatic ring around the core */
  box-shadow:
    0 0 8px  rgba(180, 220, 255, 0.45),
    0 0 16px rgba(255, 200, 200, 0.18);

  pointer-events: none;
  mix-blend-mode: screen;
  z-index: 100;          /* below sidebar (20) but above main UI (10) — wait, actually higher */
  /* Override: needs to sit on top of everything */
}

/* Force it on top of all other UI without intercepting clicks */
.cursor-lens {
  z-index: 9999;
}
</file>

<file path="src/components/shared/CursorLens.jsx">
// src/components/shared/CursorLens.jsx
// Small lens-flare dot that appears at the cursor when it's near the orb rim.
// Driven by useCursorRefraction. Uses Framer Motion for spring-trailed
// position so the flare follows the cursor with a tiny lag, evoking
// "touching a glass surface."

import React from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import useSettingsStore     from '../../store/settingsStore';
import useCursorRefraction  from '../../hooks/useCursorRefraction';
import './CursorLens.css';

const ORB_SCALE_HINT = { small: 0.75, medium: 1.0, large: 1.25 };

export default function CursorLens() {
  const orbSize = useSettingsStore((s) => s.orbSize);
  const { visible, x, y } = useCursorRefraction(ORB_SCALE_HINT[orbSize] ?? 1);

  return (
    <AnimatePresence>
      {visible && (
        <motion.div
          key="cursor-lens"
          className="cursor-lens"
          initial={{ opacity: 0, scale: 0.5 }}
          animate={{
            opacity: 0.45,
            scale:   1,
            x:       x,
            y:       y,
          }}
          exit={{ opacity: 0, scale: 0.5 }}
          transition={{
            opacity: { duration: 0.18, ease: 'easeOut' },
            scale:   { duration: 0.18, ease: 'easeOut' },
            x:       { type: 'spring', stiffness: 800, damping: 35, mass: 0.15 },
            y:       { type: 'spring', stiffness: 800, damping: 35, mass: 0.15 },
          }}
          aria-hidden="true"
        />
      )}
    </AnimatePresence>
  );
}
</file>

<file path="src/components/shared/FloatingStatusChip.css">
/* src/components/shared/FloatingStatusChip.css
   ─────────────────────────────────────────────────────────────────────────
   Tiny pill that floats above the orb showing the current ARIA phase.
   Phase-aware colour via --fsc-accent / --fsc-border / --fsc-glow vars
   set inline from the component.
   ───────────────────────────────────────────────────────────────────────── */


/* ── Positioner — fixed, centered, just above the orb ────────────── */
.fsc__positioner {
  position:        fixed;
  top:             29%;
  left:            50%;
  transform:       translateX(-50%);
  z-index:         15;
  pointer-events:  none;
  display:         flex;
  justify-content: center;
}


/* ── Chip pill ────────────────────────────────────────────────────── */
.fsc__chip {
  display:     inline-flex;
  align-items: center;
  gap:         6px;
  padding:     4px 11px 4px 8px;
  border-radius: 20px;

  /* Frosted glass — dark in obsidian, light in crystal */
  background:      rgba(10, 8, 18, 0.52);
  backdrop-filter: blur(14px) saturate(1.5);
  -webkit-backdrop-filter: blur(14px) saturate(1.5);

  /* Phase-aware border + outer glow */
  border:     1px solid var(--fsc-border, rgba(100, 160, 255, 0.28));
  box-shadow:
    0 0 14px var(--fsc-glow,   rgba(100, 160, 255, 0.14)),
    0 2px  8px rgba(0, 0, 0, 0.18),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

body.crystal .fsc__chip {
  background:  rgba(248, 243, 255, 0.68);
  box-shadow:
    0 0 14px var(--fsc-glow,   rgba(100, 160, 255, 0.10)),
    0 2px  8px rgba(0, 0, 0, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.55);
}


/* ── Live dot — pulses gently ─────────────────────────────────────── */
.fsc__dot {
  width:         5px;
  height:        5px;
  border-radius: 50%;
  background:    var(--fsc-accent, rgba(100, 160, 255, 0.90));
  flex-shrink:   0;
  box-shadow:    0 0 5px var(--fsc-accent, rgba(100, 160, 255, 0.90));
  animation:     fsc-dot-pulse 2.2s ease-in-out infinite;
  /* Pause the animation during the chip's own mount/exit to avoid jitter */
}

@keyframes fsc-dot-pulse {
  0%, 100% { opacity: 0.65; transform: scale(1.00); }
  50%       { opacity: 1.00; transform: scale(1.30); }
}


/* ── Label text ───────────────────────────────────────────────────── */
.fsc__label {
  font-family:    var(--font-ui, 'Inter', system-ui, sans-serif);
  font-size:      9px;
  font-weight:    600;
  letter-spacing: 0.18em;
  color:          var(--fsc-accent, rgba(100, 160, 255, 0.90));
  white-space:    nowrap;
  line-height:    1;
  text-transform: uppercase;
  /* Soft text glow */
  text-shadow:    0 0 10px var(--fsc-glow, rgba(100, 160, 255, 0.20));
}

body.crystal .fsc__label {
  /* Crystal: slightly darken so it reads on light bg */
  filter: brightness(0.75);
}
</file>

<file path="src/components/shared/FloatingStatusChip.jsx">
// src/components/shared/FloatingStatusChip.jsx
//
// Tiny pill that floats above the orb and broadcasts the current ARIA phase.
// Transitions on every phase change via AnimatePresence key={phase}.
//
// Position: fixed, top ≈ 29%, centered — sits in the negative space between
// the orb top and the window header, never overlapping orb geometry.

import React from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import useAriaStore from '../../store/ariaStore';
import './FloatingStatusChip.css';

// ── Phase display config ──────────────────────────────────────────────────────
const CHIP_CONFIG = {
  idle:       {
    label:  'IDLE',
    accent: 'rgba(100, 160, 255, 0.90)',
    border: 'rgba(100, 160, 255, 0.28)',
    glow:   'rgba(100, 160, 255, 0.14)',
  },
  planning:   {
    label:  'PLANNING',
    accent: 'rgba(190, 130, 255, 0.90)',
    border: 'rgba(190, 130, 255, 0.28)',
    glow:   'rgba(190, 130, 255, 0.14)',
  },
  executing:  {
    label:  'EXECUTING',
    accent: 'rgba( 60, 220, 180, 0.90)',
    border: 'rgba( 60, 220, 180, 0.28)',
    glow:   'rgba( 60, 220, 180, 0.14)',
  },
  recovering: {
    label:  'RECOVERING',
    accent: 'rgba(255, 200,  80, 0.90)',
    border: 'rgba(255, 200,  80, 0.28)',
    glow:   'rgba(255, 200,  80, 0.14)',
  },
  error:      {
    label:  'ERROR',
    accent: 'rgba(255,  80,  80, 0.90)',
    border: 'rgba(255,  80,  80, 0.28)',
    glow:   'rgba(255,  80,  80, 0.14)',
  },
  complete:   {
    label:  'COMPLETE',
    accent: 'rgba( 80, 255, 150, 0.90)',
    border: 'rgba( 80, 255, 150, 0.28)',
