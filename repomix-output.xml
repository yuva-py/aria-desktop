  padding:     10px 4px;
  position:    relative;
  /* Needed for the hover left-border pseudo-element */
  overflow:    visible;
}

/* Hover: spectral left border slides in from the left */
.pipeline-node::before {
  content:    '';
  position:   absolute;
  left:       -4px;
  top:        0;
  bottom:     0;
  width:      2px;
  border-radius: 1px;
  background: linear-gradient(
    180deg,
    var(--accent, rgba(150, 100, 255, 0.9)),
    rgba(100, 180, 255, 0.50)
  );
  opacity:   0;
  transform: translateX(-2px);
  transition: opacity 150ms ease, transform 150ms ease;
  pointer-events: none;
}

.pipeline-node:hover::before {
  opacity:   1;
  transform: translateX(0);
}

/* ── Track column (line + dot) ───────────────────────────── */
.pipeline-node__track {
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  flex-shrink:     0;
  width:           16px;
  padding-top:     2px;
  position:        relative;
}

.pipeline-node__dot {
  width:         10px;
  height:        10px;
  border-radius: 50%;
  flex-shrink:   0;
  transition:    background 0.3s ease, box-shadow 0.3s ease;
  position:      relative;
  z-index:       1;
}

/* Connector line beneath the dot */
.pipeline-node__line {
  position:      absolute;
  top:           14px;
  left:          50%;
  transform:     translateX(-50%);
  width:         1px;
  bottom:        -10px;
  background:    rgba(255, 255, 255, 0.09);
  overflow:      hidden;
}

body.crystal .pipeline-node__line {
  background: rgba(124, 58, 237, 0.14);
}

/* Traveling signal pulse on the connector line above an active node */
.pipeline-node--active .pipeline-node__line::before {
  content:       '';
  position:      absolute;
  left:          50%;
  transform:     translateX(-50%);
  width:         3px;
  height:        8px;
  border-radius: 4px;
  background:    var(--accent, rgba(150, 100, 255, 1));
  box-shadow:    0 0 6px var(--accent, rgba(150, 100, 255, 0.8));
  animation:     pipeline-signal 1.5s linear infinite;
}

@keyframes pipeline-signal {
  0%   { top: 0;    opacity: 1; }
  85%  { top: 100%; opacity: 0.8; }
  100% { top: 100%; opacity: 0;   }
}

/* ── Tool dispatch flash ──────────────────────────────────── */
/* Applied briefly when a new tool is dispatched — white spike */
.tool-pill--flash {
  animation: tool-dispatch-flash 0.22s ease-out both;
}

@keyframes tool-dispatch-flash {
  0%   { filter: brightness(1);   }
  40%  { filter: brightness(2.8) saturate(0.2); }
  100% { filter: brightness(1);   }
}

/* ── Goal completion burst ─────────────────────────────────── */
/* A scale+glow burst on the success dot */
.pipeline-node__dot--burst {
  animation: dot-success-burst 0.45s ease-out both;
}

@keyframes dot-success-burst {
  0%   { transform: scale(1);   box-shadow: 0 0 0   0 rgba(80, 255, 160, 0);   }
  40%  { transform: scale(2.2); box-shadow: 0 0 14px 4px rgba(80, 255, 160, 0.7); }
  100% { transform: scale(1);   box-shadow: 0 0 6px  2px rgba(80, 255, 160, 0.2); }
}

/* ── Content column ──────────────────────────────────────── */
.pipeline-node__content {
  flex:       1;
  min-width:  0;
  padding-top: 0;
}

.pipeline-node__text {
  font-size:     13px;
  font-weight:   300;
  font-family:   var(--font-ui);
  color:         var(--text-primary);
  max-width:     200px;
  white-space:   nowrap;
  overflow:      hidden;
  text-overflow: ellipsis;
  line-height:   1.4;
  margin-bottom: 4px;
}

/* ── Tool row (active state) ─────────────────────────────── */
.pipeline-node__tool-row {
  display:     flex;
  align-items: center;
  gap:         6px;
  margin-top:  3px;
}

.pipeline-node__arrow {
  font-size:  11px;
  color:      var(--text-secondary);
  flex-shrink: 0;
}

/* ── Tool colour pill ────────────────────────────────────── */
.pipeline-pill {
  display:        inline-flex;
  align-items:    center;
  gap:            3px;
  font-size:      11px;
  font-weight:    500;
  font-family:    var(--font-mono);
  padding:        2px 7px;
  border-radius:  5px;
  letter-spacing: 0.02em;
  white-space:    nowrap;
}

.pipeline-pill__action {
  opacity: 0.75;
}

/* ── Recovering label ────────────────────────────────────── */
.pipeline-node__recovering {
  font-size:   11px;
  color:       rgba(251, 191, 36, 0.9);
  margin-top:  3px;
  font-family: var(--font-mono);
}
</file>

