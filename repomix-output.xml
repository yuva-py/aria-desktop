<file path="python/stub_server.py">
# FastAPI stub server for ARIA desktop — Phase 1
# Port : 7331
# Routes:
#   POST /process  — accepts {"input": str}, returns {"success": True, "message": "stub response"}
#   WS   /stream   — on connect, loops forever emitting one event per second,
#                    cycling through the 8 canonical ARIA events in order.

from __future__ import annotations

import asyncio
import json
import logging

import uvicorn
from fastapi import FastAPI, WebSocket, WebSocketDisconnect
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

# ── Logging ───────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="[ARIA stub] %(levelname)s  %(message)s",
)
log = logging.getLogger(__name__)

# ── App ───────────────────────────────────────────────────────────────────────
app = FastAPI(title="ARIA Stub Server", version="0.1.0")

# Allow the Electron renderer (localhost:5173) to call the HTTP endpoint.
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# ── Event cycle ───────────────────────────────────────────────────────────────
# The WebSocket streams these events in order, wrapping back to the start after
# the last one.  Each entry is already serialised to a JSON string so the hot
# path in the loop is just an await, not a serialise + await.
_RAW_EVENTS: list[dict] = [
    {
        "event": "goal_planned",
        "data": {"goals": ["open Chrome", "search weather"], "count": 2},
    },
    {
        "event": "goal_started",
        "data": {"goal": "open Chrome", "index": 1},
    },
    {
        "event": "tool_dispatched",
        "data": {"tool": "browser_tool", "action": "navigate"},
    },
    {
        "event": "tool_result",
        "data": {"success": True, "summary": "navigated to google.com"},
    },
    {
        "event": "recovery_triggered",
        "data": {"reason": "window not found"},
    },
    {
        "event": "goal_completed",
        "data": {"index": 1, "success": True},
    },
    {
        "event": "tier3_required",
        "data": {"action": "delete_file", "path": "C:/Users/test/report.pdf"},
    },
    {
        "event": "session_complete",
        "data": {"response": "Done. All goals completed."},
    },
]

# Pre-serialise once at import time.
EVENTS: list[str] = [json.dumps(e) for e in _RAW_EVENTS]
EVENT_COUNT: int = len(EVENTS)


# ── POST /process ─────────────────────────────────────────────────────────────
class ProcessRequest(BaseModel):
    input: str


class ProcessResponse(BaseModel):
    success: bool
    message: str


@app.post("/process", response_model=ProcessResponse)
async def process(body: ProcessRequest) -> ProcessResponse:
    """Accept a text command and return a stub acknowledgement."""
    log.info("POST /process  input=%r", body.input)
    return ProcessResponse(success=True, message="stub response")


# ── WS /stream ────────────────────────────────────────────────────────────────
@app.websocket("/stream")
async def stream(ws: WebSocket) -> None:
    """
    On connect, emit one event per second cycling through EVENTS indefinitely.
    The loop exits cleanly when the client disconnects.
    """
    await ws.accept()
    log.info("WS /stream  client connected  %s", ws.client)

    index = 0
    try:
        while True:
            payload = EVENTS[index % EVENT_COUNT]
            await ws.send_text(payload)
            log.debug("WS /stream  sent event[%d]  %s", index % EVENT_COUNT, payload)
            index += 1
            await asyncio.sleep(1)
    except WebSocketDisconnect:
        log.info("WS /stream  client disconnected  %s", ws.client)
    except Exception as exc:  # noqa: BLE001
        log.error("WS /stream  unexpected error: %s", exc)
        await ws.close(code=1011)


# ── Entry point ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    log.info("Starting ARIA stub server on http://0.0.0.0:7331")
    uvicorn.run(
        "stub_server:app",
        host="0.0.0.0",
        port=7331,
        log_level="info",
        reload=False,
    )
</file>

