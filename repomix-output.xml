/* src/App.css — ARIA root layout */

/* ── Root shell ───────────────────────────────────────────── */
.aria-app {
  width:      100vw;
  height:     100vh;
  overflow:   visible; /* NOT hidden — hidden creates the visible box */
  position:   relative;
  background: transparent;
}

/* ── UI layer — floats above the WebGL canvas ─────────────── */
.aria-ui-layer {
  position:       absolute;
  inset:          0;
  z-index:        10;
  display:        flex;
  flex-direction: column;
  pointer-events: none;
  background:     transparent;
  overflow:       visible;
}

/* Re-enable pointer events only on interactive nodes */
.aria-app__topbar,
.aria-app__footer {
  pointer-events: auto;
}

/* ── Top bar (holds ThemeToggle) ──────────────────────────── */
.aria-app__topbar {
  position:    absolute;
  top:         16px;
  right:       16px;
  z-index:     20;
  display:     flex;
  align-items: center;
  gap:         8px;
  background:  transparent;
}

/* ── Main — holds LiveStrip, below orb above command bar ─── */
/* Orb visual centre ≈ 38%, visual bottom edge ≈ 58%.         */
/* padding-top pushes LiveStrip into the clear zone below.    */
.aria-app__main {
  flex:            1;
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  justify-content: flex-start;
  padding-top:     63vh;
  background:      transparent;
  pointer-events:  none;
}

/* ── Footer (CommandBar) ──────────────────────────────────── */
.aria-app__footer {
  /* Fixed to bottom — consistent 40px clearance regardless of screen height */
  position:   fixed;
  bottom:     40px;
  left:       50%;
  transform:  translateX(-50%);
  width:      100%;
  max-width:  640px;
  padding:    0 32px;
  background: transparent;
}

/* ── Screen edge vignette ─────────────────────────────────── */
/* Fixed full-viewport overlay that darkens screen edges,       */
/* making the orb at center feel lit and spatially grounded.     */
.aria-vignette {
  position:       fixed;
  inset:          0;
  z-index:        1;
  pointer-events: none;
  background:     radial-gradient(
    ellipse at 50% 38%,
    transparent 38%,
    rgba(0, 0, 0, 0.48) 100%
  );
}

/* ── Orb ambient floor glow ───────────────────────────────── */
/* A soft elliptical gradient bloom below the orb center.        */
/* Color is read from --spectral-primary so it tracks the theme. */
.aria-floor-glow {
  position:       absolute;
  left:           50%;
  top:            46%;
  transform:      translateX(-50%);
  width:          300px;
  height:         60px;
  z-index:        1;
  pointer-events: none;
  background:     radial-gradient(
    ellipse,
    var(--spectral-primary, #8b5cf6) 0%,
    transparent 70%
  );
  opacity:        0.15;
  filter:         blur(20px);
}

/* ── Orb ground halo ──────────────────────────────────────── */
/* Narrower, sharper ellipse just below the orb — like the     */
/* glowing ground shadow of a hovering sphere.                   */
.orb-ground-halo {
  position:       absolute;
  width:          280px;
  height:         40px;
  left:           50%;
  top:            52%;
  transform:      translateX(-50%);
  z-index:        1;
  pointer-events: none;
  background:     radial-gradient(
    ellipse,
    var(--spectral-primary, #8b5cf6) 0%,
    transparent 70%
  );
  opacity:        0.12;
  filter:         blur(16px);
  transition:     opacity 0.5s ease, background 0.5s ease;
}

body.obsidian .orb-ground-halo { opacity: 0.18; }
body.crystal  .orb-ground-halo { opacity: 0.08; }
</file>

